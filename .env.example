# این فایل را داخل GitHub با رمز واقعی پر نکنید.
# مقادیر حساس را در Railway > Service > Variables وارد کنید.

TZ=Europe/Berlin

# Railway متغیر PORT را خودکار می‌سازد.
UVICORN_HOST=0.0.0.0

XRAY_EXECUTABLE_PATH=/usr/local/bin/xray
XRAY_ASSETS_PATH=/usr/local/share/xray
XRAY_JSON=/var/lib/marzban/xray_config.json

# دیتابیس روی Railway Volume
SQLALCHEMY_DATABASE_URL=sqlite:////var/lib/marzban/db.sqlite3

# فقط برای اولین راه‌اندازی
SUDO_USERNAME=admin
SUDO_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD

# بعد از ساخت دامنه پنل، این مقدار را در Railway تنظیم کنید.
# مثال:
# XRAY_SUBSCRIPTION_URL_PREFIX=https://your-panel.up.railway.app

DASHBOARD_PATH=/dashboard/
DOCS=False
DEBUG=False
